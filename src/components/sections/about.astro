---
import { AnimateIn } from "@/components/ui/animate-in";
import type { AboutEntry } from "@/types/sections.types";

interface AboutProps {
  aboutData?: AboutEntry;
}

const { aboutData } = Astro.props as AboutProps;

const { Content } = await aboutData!.render();
const data = aboutData!.data;
---

<section id="about" class="relative px-6 py-24 md:py-32">
  <div class="mx-auto max-w-6xl">
    <AnimateIn client:visible>
      <div class="mb-12 flex items-center gap-4">
        <h2
          class="text-foreground flex items-center gap-2 text-3xl font-bold tracking-tight md:text-4xl"
        >
          <span class="text-primary font-mono text-xl md:text-2xl"> 01. </span>
          {data.title}
        </h2>
        <div
          class="from-primary/40 h-px flex-1 bg-gradient-to-r to-transparent"
        >
        </div>
      </div>
    </AnimateIn>

    <div class="grid items-start gap-8 md:grid-cols-5">
      <div class="grid gap-6 md:col-span-3">
        <AnimateIn delay={200} client:visible>
          <div
            class="group bg-secondary/20 hover:bg-secondary/30 relative overflow-hidden rounded-3xl border border-white/5 p-8 backdrop-blur-md transition-all duration-500 hover:-translate-y-1"
          >
            <div
              class="bg-primary/5 group-hover:bg-primary/10 pointer-events-none absolute -top-20 -right-20 h-64 w-64 rounded-full blur-3xl transition-all duration-500"
            >
            </div>

            <div
              class="text-muted-foreground/90 prose prose-invert relative z-10 max-w-none text-base leading-relaxed md:text-lg"
            >
              <Content />
            </div>
          </div>
        </AnimateIn>

        <AnimateIn delay={300} client:visible>
          <div
            class="group bg-secondary/20 hover:bg-secondary/30 relative overflow-hidden rounded-3xl border border-white/5 p-8 backdrop-blur-md transition-all duration-500 hover:-translate-y-1"
          >
            <div class="text-foreground mb-6 text-xl font-bold tracking-tight">
              {data.skillsTitle}
            </div>

            <ul class="grid grid-cols-2 gap-x-4 gap-y-4 sm:grid-cols-3">
              {
                data.skills.map((skill) => (
                  <li class="group/item flex w-full items-center gap-2 font-mono text-sm transition-transform duration-300 hover:translate-x-1">
                    <span class={`text-xs ${skill.color}`}>{">"}</span>
                    <span class="text-muted-foreground transition-colors group-hover/item:text-white">
                      {skill.title}
                    </span>
                  </li>
                ))
              }
            </ul>
          </div>
        </AnimateIn>
      </div>

      <div class="md:col-span-2">
        <AnimateIn delay={400} direction="right" client:visible>
          <div
            class="group relative mx-auto w-full max-w-sm transition-all duration-500 hover:-translate-y-2"
          >
            <div
              class="from-primary/20 via-accent/10 to-cyan/20 relative overflow-hidden rounded-3xl bg-gradient-to-br p-1"
            >
              <div
                class="bg-secondary/80 relative flex aspect-square items-center justify-center overflow-hidden rounded-[1.35rem] backdrop-blur-md"
              >
                {
                  /* Decorative elements representing code/abstract art instead of a solid box */
                }
                <div
                  class="absolute inset-0 bg-[linear-gradient(to_right,#80808012_1px,transparent_1px),linear-gradient(to_bottom,#80808012_1px,transparent_1px)] bg-[size:24px_24px]"
                >
                </div>
                <div
                  class="bg-primary/20 group-hover:bg-primary/30 absolute top-1/2 left-1/2 h-32 w-32 -translate-x-1/2 -translate-y-1/2 rounded-full blur-2xl transition-all duration-500 group-hover:scale-150"
                >
                </div>

                <div
                  class="text-primary/50 relative z-10 font-mono text-6xl font-bold tracking-tighter mix-blend-overlay transition-transform duration-500 group-hover:scale-110"
                >
                  {"< />"}
                </div>
              </div>
              <div
                class="from-primary/20 to-accent/20 pointer-events-none absolute inset-0 bg-gradient-to-br via-transparent transition-opacity duration-500 group-hover:opacity-0"
              >
              </div>
            </div>

            {/* Animated glowing border behind */}
            <div
              class="border-primary/20 group-hover:border-primary/40 absolute -right-4 -bottom-4 -z-10 h-full w-full rounded-3xl border-2 transition-all duration-500 group-hover:-right-5 group-hover:-bottom-5 group-hover:shadow-[0_0_40px_rgba(114,30,150,0.15)]"
            >
            </div>
          </div>
        </AnimateIn>
      </div>
    </div>
  </div>
</section>
