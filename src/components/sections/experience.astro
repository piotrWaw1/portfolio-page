---
import { AnimateIn } from "@/components/ui/animate-in";
import type { ExperienceEntry } from "@/types/sections.types";

interface ExperienceProps {
  experienceData?: ExperienceEntry;
}

const tagColors = [
  "bg-primary/10 text-primary border-primary/20",
  "bg-accent/10 text-accent border-accent/20",
  "bg-cyan/10 text-cyan border-cyan/20",
  "bg-amber/10 text-amber border-amber/20",
  "bg-rose/10 text-rose border-rose/20",
];

const JOB_STYLES = [
  {
    accent: "group-hover:text-primary",
    border: "hover:border-primary/50",
    glow: "hover:shadow-[0_0_30px_rgba(114,30,150,0.15)]",
  },
  {
    accent: "group-hover:text-accent",
    border: "hover:border-accent/50",
    glow: "hover:shadow-[0_0_30px_rgba(178,45,310,0.15)]",
  },
  {
    accent: "group-hover:text-cyan",
    border: "hover:border-cyan/50",
    glow: "hover:shadow-[0_0_30px_rgba(122,43,195,0.15)]",
  },
  {
    accent: "group-hover:text-amber",
    border: "hover:border-amber/50",
    glow: "hover:shadow-[0_0_30px_rgba(140,38,75,0.15)]",
  },
  {
    accent: "group-hover:text-rose",
    border: "hover:border-rose/50",
    glow: "hover:shadow-[0_0_30px_rgba(132,45,5,0.15)]",
  },
];

const { experienceData } = Astro.props as ExperienceProps;

const data = experienceData?.data;
---

<section id="experience" class="mesh-bg-warm relative px-6 py-24 md:py-32">
  <div class="mx-auto max-w-6xl">
    <AnimateIn client:visible>
      <div class="mb-12 flex items-center gap-4">
        <h2
          class="text-foreground flex items-center gap-2 text-3xl font-bold tracking-tight md:text-4xl"
        >
          <span class="text-accent font-mono text-xl md:text-2xl"> 02. </span>
          {data?.title}
        </h2>
        <div class="from-accent/40 h-px flex-1 bg-gradient-to-r to-transparent">
        </div>
      </div>
    </AnimateIn>

    <div class="flex flex-col gap-6">
      {
        data?.jobs.map((exp, index) => (
          <AnimateIn delay={index * 100} client:visible>
            <div
              class={`group bg-secondary/20 hover:bg-secondary/40 relative flex h-full flex-col justify-between overflow-hidden rounded-3xl border border-white/5 p-6 backdrop-blur-md transition-all duration-500 hover:-translate-y-1 ${JOB_STYLES[index % JOB_STYLES.length].border} ${JOB_STYLES[index % JOB_STYLES.length].glow}`}
            >
              {/* Subtle ambient glow in the corner */}
              <div class="text-muted-foreground mb-4 font-mono text-sm tracking-wider uppercase">
                {exp.period}
              </div>
              <div>
                <h3
                  class={`text-foreground flex items-center gap-2 text-xl font-medium ${JOB_STYLES[index].accent}`}
                >
                  {exp.title} &middot; {exp.company}
                </h3>
                <p class="text-muted-foreground mt-4 text-sm leading-relaxed">
                  {exp.description}
                </p>
                <div class="mt-4 flex flex-wrap gap-2">
                  {exp.tags.map((tag, tagIndex) => (
                    <span
                      class={`rounded-full border px-3 py-1 font-mono text-xs ${tagColors[tagIndex % tagColors.length]}`}
                    >
                      {tag}
                    </span>
                  ))}
                </div>
              </div>
            </div>
          </AnimateIn>
        ))
      }
    </div>
  </div>
</section>
