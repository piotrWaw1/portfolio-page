---
import { Github, Linkedin, Mail, Phone } from "@lucide/astro";
import { FooterContactCopy } from "../footer-contact-copy";
import { getLangFromUrl, useTranslations } from "@/i18n/utils";

const socialLinks = [
  {
    icon: Github,
    href: "https://github.com/piotrWaw1",
    label: "GitHub",
    color: "hover:text-primary",
  },
  {
    icon: Linkedin,
    href: "https://www.linkedin.com/in/piotr-wawrze%C5%84czyk-6aa15a262/",
    label: "LinkedIn",
    color: "hover:text-blue",
  },
  {
    icon: Mail,
    href: "mailto:p.wawrzenczyk1@gmail.com",
    label: "Email",
    color: "hover:text-amber",
  },
];

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<footer class="border-border/30 border-t px-6 py-12">
  <div class="mx-auto flex max-w-6xl flex-col items-center gap-6">
    <div class="flex items-center gap-6">
      {
        socialLinks.map((link) => (
          <a
            href={link.href}
            aria-label={link.label}
            class={`text-muted-foreground transition-all hover:-translate-y-0.5 ${link.color}`}
          >
            <link.icon class="h-5 w-5" />
          </a>
        ))
      }
    </div>
    <FooterContactCopy client:visible />
    <p class="text-muted-foreground font-mono text-sm">
      {t("footer.designedAndBuiltBy")}{" "}
      <span class="gradient-text">Piotr Wawrzeńczyk</span>
    </p>
  </div>
</footer>
