---
import { Layout } from "@lucide/astro";
import AppWindow from "@lucide/astro/icons/app-window";
import Gauge from "@lucide/astro/icons/gauge";
import Globe from "@lucide/astro/icons/globe";
import Palette from "@lucide/astro/icons/palette";
import ShoppingCart from "@lucide/astro/icons/shopping-cart";
import { AnimateIn } from "../ui/animate-in";

const services = [
  {
    icon: Layout,
    title: "Landing Pages",
    description:
      "High-converting, beautifully designed landing pages tailored to your brand. Optimized for speed, SEO, and mobile-first responsiveness to maximize engagement.",
    tags: ["SEO Optimized", "Responsive", "Fast Load"],
    color: "text-primary",
    borderColor: "hover:border-primary/40",
    bgColor: "bg-primary/5",
    glowClass: "glow-green",
  },
  {
    icon: Globe,
    title: "Business Websites",
    description:
      "Professional multi-page websites that establish your online presence. Complete with content management, contact forms, analytics, and everything your business needs.",
    tags: ["Gotowe CMS", "Wielostronicowe", "Analityka"],
    color: "text-cyan",
    borderColor: "hover:border-cyan/40",
    bgColor: "bg-cyan/5",
    glowClass: "",
  },
  {
    icon: ShoppingCart,
    title: "E-commerce Solutions",
    description:
      "Custom online stores with secure payment processing, inventory management, and a seamless shopping experience that drives sales and customer loyalty.",
    tags: ["Payments", "Inventory", "Cart System"],
    color: "text-amber",
    borderColor: "hover:border-amber/40",
    bgColor: "bg-amber/5",
    glowClass: "",
  },
  {
    icon: AppWindow,
    title: "Web Applications",
    description:
      "Full-featured web apps with user authentication, databases, dashboards, and complex business logic. From SaaS platforms to internal tools -- we build it all.",
    tags: ["Auth & Roles", "Database", "Dashboard"],
    color: "text-accent",
    borderColor: "hover:border-accent/40",
    bgColor: "bg-accent/5",
    glowClass: "glow-pink",
  },
  {
    icon: Palette,
    title: "UI/UX Redesign",
    description:
      "Breathe new life into your existing website with a modern redesign. We audit your current site, identify improvements, and deliver a refreshed, user-friendly experience.",

    tags: ["Audit", "Modern UI", "UX Research"],
    color: "text-rose",
    borderColor: "hover:border-rose/40",
    bgColor: "bg-rose/5",
    glowClass: "",
  },
  {
    icon: Gauge,
    title: "Performance & SEO",
    description:
      "Already have a site? We optimize loading speed, Core Web Vitals, accessibility, and search engine ranking to help you reach more customers organically.",
    tags: ["Core Vitals", "A11y", "Speed Boost"],
    color: "text-blue",
    borderColor: "hover:border-blue/40",
    bgColor: "bg-blue/5",
    glowClass: "",
  },
];
---

<section id="services" class="px-6 py-24 md:py-32">
  <div class="mx-auto max-w-6xl">
    <AnimateIn client:visible>
      <div class="mb-4 flex items-center gap-4">
        <h2
          class="text-foreground flex items-center gap-2 text-2xl font-bold md:text-3xl"
        >
          <span class="text-primary font-mono text-lg md:text-xl"> 01. </span>
          What We Build
        </h2>
        <div
          class="from-primary/40 h-px flex-1 bg-gradient-to-r to-transparent"
        >
        </div>
      </div>
    </AnimateIn>

    <AnimateIn delay={100} client:visible>
      <p class="text-muted-foreground mb-14 max-w-2xl leading-relaxed">
        Whether you need a simple landing page or a complex web application with
        authentication and databases, we have you covered. Every project is
        built with clean code, modern design, and your business goals in mind."
      </p>
    </AnimateIn>

    <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {
        services.map((service, i) => (
          <AnimateIn delay={i * 80} client:visible>
            <div
              class={`group border-border/50 flex h-full flex-col rounded-2xl border ${service.bgColor} p-6 transition-all hover:-translate-y-1 ${service.borderColor} ${service.glowClass} md:p-7`}
            >
              <div
                class={`bg-secondary/50 mb-5 inline-flex h-12 w-12 items-center justify-center rounded-xl ${service.color}`}
              >
                <service.icon class="h-6 w-6" />
              </div>
              <h3 class="text-foreground mb-3 text-lg font-semibold">
                {service.title}
              </h3>
              <p class="text-muted-foreground mb-5 flex-1 text-sm leading-relaxed">
                {service.description}
              </p>
              <div class="flex flex-wrap gap-2">
                {service.tags.map((tag) => (
                  <span
                    class={`border-border/50 rounded-full border px-3 py-1 font-mono text-xs ${service.color}/70`}
                  >
                    {tag}
                  </span>
                ))}
              </div>
            </div>
          </AnimateIn>
        ))
      }
    </div>
  </div>
</section>
