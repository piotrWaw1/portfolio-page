---
import { Sparkles, ArrowDown } from "@lucide/astro";
import { AnimateIn } from "../ui/animate-in";
import type { HeroEntry } from "@/types/sections.types";
import { getLangFromUrl, useTranslations } from "@/i18n/utils";

interface HeroProps {
  heroData?: HeroEntry;
}

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const { heroData } = Astro.props as HeroProps;

const { Content } = await heroData!.render();
const data = heroData!.data;
---

<section id="hero" class="mesh-bg relative flex min-h-screen items-center px-6">
  <div class="pointer-events-none absolute inset-0 overflow-hidden">
    <div
      class="bg-primary/5 absolute top-1/4 right-1/4 h-72 w-72 rounded-full blur-3xl"
    >
    </div>
    <div
      class="bg-accent/5 absolute bottom-1/3 left-1/4 h-64 w-64 rounded-full blur-3xl"
    >
    </div>
    <div
      class="bg-cyan/5 absolute top-1/2 right-1/3 h-48 w-48 rounded-full blur-3xl"
    >
    </div>
  </div>

  <div class="relative mx-auto w-full max-w-6xl">
    <AnimateIn delay={100} client:visible>
      <div
        class="border-primary/30 bg-primary/5 mb-6 inline-flex items-center gap-2 rounded-full border px-4 py-1.5"
      >
        <Sparkles class="text-primary h-4 w-4" />
        <span class="text-primary font-mono text-sm">
          {data.badge}
        </span>
      </div>
    </AnimateIn>

    <AnimateIn delay={200} client:visible>
      <h1
        class="max-w-4xl text-4xl leading-tight font-bold tracking-tight sm:text-5xl md:text-7xl"
      >
        <span class="text-foreground/90"
          >{t("offer.hero.weDesignAndBuild")}</span
        >
        <span class="gradient-text">{t("offer.hero.websideThatGrow")}</span>
        <span class="text-foreground/90">{t("offer.hero.yourBusiness")}</span>
      </h1>
    </AnimateIn>

    <AnimateIn delay={300} client:visible>
      <div
        class="text-muted-foreground mt-6 max-w-xl text-base leading-relaxed md:max-w-2xl md:text-lg"
      >
        <Content />
      </div>
    </AnimateIn>

    <AnimateIn delay={400} client:visible>
      <div class="mt-10 flex flex-wrap items-center gap-4">
        <a
          href="#contact"
          class="glow-green border-primary/40 bg-primary/10 text-primary hover:border-primary/60 hover:bg-primary/20 inline-flex items-center gap-2 rounded-xl border px-7 py-3.5 font-mono text-sm transition-all"
        >
          {t("offer.hero.startProject")}
        </a>
        <a
          href="#services"
          class="border-border/50 bg-secondary/50 text-foreground hover:border-accent/40 hover:bg-secondary inline-flex items-center gap-2 rounded-xl border px-7 py-3.5 font-mono text-sm transition-all"
        >
          {t("offer.hero.seeWhatWeOffer")}
          <ArrowDown class="h-4 w-4" />
        </a>
      </div>
    </AnimateIn>
  </div>
</section>
